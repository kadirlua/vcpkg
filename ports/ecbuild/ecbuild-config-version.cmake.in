# ecCodes calls find_package(ecbuild 3.7), so CMake requires a package
# version file next to ecbuild-config.cmake. The actual selected ecbuild
# version is controlled by vcpkg before CMake configure is invoked.
set(PACKAGE_VERSION "@VERSION@")
set(PACKAGE_VERSION_COMPATIBLE TRUE)

if(PACKAGE_FIND_VERSION VERSION_EQUAL PACKAGE_VERSION)
    set(PACKAGE_VERSION_EXACT TRUE)
endif()
